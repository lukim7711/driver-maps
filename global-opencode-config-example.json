{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "username": "your-username",
  "shell": "/bin/zsh",
  "autoupdate": true,
  "snapshot": true,
  "logLevel": "INFO",

  "skills": {
    "paths": ["~/.config/opencode/skills"]
  },

  "agent": {
    "review": {
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6",
      "description": "Reviews code for quality, security, and best practices",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow"
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow"
      }
    },
    "docs-writer": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.5-plus",
      "description": "Writes and maintains project documentation",
      "temperature": 0.3,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "deny"
      }
    },
    "security-auditor": {
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6",
      "description": "Performs security audits on code and dependencies",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "grep": "allow"
      }
    }
  },

  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow"
    }
  }
}
