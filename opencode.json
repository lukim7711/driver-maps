{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "lsp": true,
  "snapshot": true,
  "instructions": ["AGENTS.md", "guidelines.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "description": "Main development agent with full tool access for writing and editing code",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "lsp": "allow",
        "skill": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/kimi-k2.6",
      "description": "Restricted agent for planning and analysis without making code changes",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "ask",
        "task": "allow",
        "lsp": "allow"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.6-plus",
      "description": "General-purpose subagent for researching complex questions and multi-step tasks",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Fast read-only agent for exploring codebases and finding files",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.5-plus",
      "description": "Read-only agent for external docs and dependency research",
      "permission": {
        "read": "allow",
        "repo_clone": "allow",
        "repo_overview": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "compaction": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "hidden": true
    },
    "title": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "hidden": true
    },
    "summary": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "hidden": true
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "grep*": "allow"
    }
  }
}
